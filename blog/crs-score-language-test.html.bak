<script>
/* ─── DATA ─── */
/* IELTS band → CLB per skill type (Listening, Reading, Writing, Speaking) */
var IELTS_L={9:10,8.5:10,8:10,7.5:9,7:9,6.5:8,6:7,5.5:6,5:5,4.5:4,4:4,3.5:4,0:4};
var IELTS_R={8.5:10,8:10,7.5:9,7:8,6.5:7,6:7,5.5:6,5:5,4.5:4,4:4,3.5:4,0:4};
var IELTS_W={7.5:10,7:9,6.5:8,6:7,5.5:6,5:5,4.5:4,4:4,3.5:4,0:4};
var IELTS_S={7.5:10,7:9,6.5:8,6:7,5.5:6,5:5,4.5:4,4:4,3.5:4,0:4};

/* CRS pts per CLB — per skill — first language */
var CLB_PTS_SINGLE={10:34,9:31,8:23,7:17,6:9,5:6,4:6};
var CLB_PTS_SPOUSE={10:32,9:29,8:22,7:16,6:8,5:6,4:6};

/* CELPIP level = CLB level (direct map) */

function lookupIelts(score,map){
  var keys=Object.keys(map).map(Number).sort(function(a,b){return b-a;});
  for(var i=0;i<keys.length;i++){if(score>=keys[i])return map[keys[i]];}
  return 4;
}

function ieltsToCLB(score,skill){
  score=parseFloat(score);
  if(isNaN(score))return null;
  if(skill==='L')return lookupIelts(score,IELTS_L);
  if(skill==='R')return lookupIelts(score,IELTS_R);
  if(skill==='W')return lookupIelts(score,IELTS_W);
  if(skill==='S')return lookupIelts(score,IELTS_S);
  return 4;
}

function clbToCRS(clb,marital){
  clb=Math.min(clb,10);
  return (marital==='spouse'?CLB_PTS_SPOUSE:CLB_PTS_SINGLE)[clb]||6;
}

function updateTestLabels(){
  var t=document.getElementById('testType').value;
  var ph={ielts:{L:'e.g. 8.0',R:'e.g. 8.0',W:'e.g. 7.5',S:'e.g. 7.5',max:9,step:.5},
          celpip:{L:'e.g. 10',R:'e.g. 10',W:'e.g. 9',S:'e.g. 9',max:12,step:1},
          tef:{L:'NCLC 1–12',R:'NCLC 1–12',W:'NCLC 1–12',S:'NCLC 1–12',max:12,step:1}};
  var p=ph[t]||ph.ielts;
  ['L','R','W','S'].forEach(function(s){
    var el=document.getElementById('score'+s);
    if(el){el.placeholder=p[s];el.max=p.max;el.step=p.step;}
  });
}

function checkLanguage(){
  var test=document.getElementById('testType').value;
  var marital=document.getElementById('langMarital').value;
  var sL=document.getElementById('scoreL').value;
  var sR=document.getElementById('scoreR').value;
  var sW=document.getElementById('scoreW').value;
  var sS=document.getElementById('scoreS').value;

  if(!sL||!sR||!sW||!sS){alert('Please enter scores for all 4 skills (Listening, Reading, Writing, Speaking).');return;}

  var clbs={L:0,R:0,W:0,S:0};
  var scores={L:parseFloat(sL),R:parseFloat(sR),W:parseFloat(sW),S:parseFloat(sS)};

  if(test==='ielts'){
    clbs.L=ieltsToCLB(scores.L,'L');
    clbs.R=ieltsToCLB(scores.R,'R');
    clbs.W=ieltsToCLB(scores.W,'W');
    clbs.S=ieltsToCLB(scores.S,'S');
  } else {
    /* CELPIP / TEF — direct CLB equivalency */
    Object.keys(scores).forEach(function(k){
      var v=Math.round(scores[k]);
      clbs[k]=Math.max(4,Math.min(12,v));
    });
  }

  var ptsL=clbToCRS(clbs.L,marital);
  var ptsR=clbToCRS(clbs.R,marital);
  var ptsW=clbToCRS(clbs.W,marital);
  var ptsS=clbToCRS(clbs.S,marital);
  var total=ptsL+ptsR+ptsW+ptsS;
  var maxPts=marital==='spouse'?128:136;
  var pct=Math.round(total/maxPts*100);

  var minCLB=Math.min(clbs.L,clbs.R,clbs.W,clbs.S);

  var verdict,bgCol;
  if(total>=136){verdict='🏆 Maximum language score — CLB 10+ all skills';bgCol='#f0fdf4';}
  else if(total>=124){verdict='✅ Excellent — CLB 9+ all skills';bgCol='#f0fdf4';}
  else if(total>=92){verdict='✅ Good — CLB 8+ range';bgCol='#eff6ff';}
  else if(total>=68){verdict='⚠️ Moderate — CLB 7 range — retaking IELTS could add 24–68 pts';bgCol='#fffbeb';}
  else{verdict='⚠️ Low — Improving language score is the highest-impact CRS action';bgCol='#fff0f0';}

  var skillNames={L:'Listening',R:'Reading',W:'Writing',S:'Speaking'};
  var html='<div style="background:'+bgCol+';border-radius:12px;padding:16px;margin-bottom:12px;">'
    +'<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;">'
    +'<div><div style="font-size:40px;font-weight:800;color:#c40000;line-height:1;">'+total+'</div>'
    +'<div style="font-size:14px;font-weight:700;color:#374151;">CRS Language Points (Section A — 1st Language)</div>'
    +'<div style="font-size:13px;color:#6b7280;margin-top:3px;">'+(marital==='spouse'?'With spouse':'Without spouse')+' | Test: '+test.toUpperCase()+'</div></div>'
    +'<div style="text-align:right;"><div style="font-size:13px;font-weight:700;color:#c40000;">'+verdict+'</div>'
    +'<div style="font-size:13px;color:#6b7280;">'+total+' / '+maxPts+' pts ('+pct+'%)</div></div></div>'
    +'<div style="background:#f3f4f6;border-radius:999px;height:8px;margin-top:12px;overflow:hidden;">'
    +'<div style="width:'+pct+'%;height:100%;border-radius:999px;background:linear-gradient(90deg,#c40000,#ff4444);"></div></div></div>';

  /* Per-skill breakdown */
  html+='<div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:14px;margin-bottom:10px;">'
    +'<div style="font-size:13px;font-weight:700;margin-bottom:10px;color:#111827;">📊 Per-Skill Breakdown</div>'
    +'<table style="width:100%;border-collapse:collapse;">';
  ['L','R','W','S'].forEach(function(k){
    var clbLabel=clbs[k]>=10?'CLB 10+':'CLB '+clbs[k];
    html+='<tr style="border-bottom:1px solid #f0f0f0;">'
      +'<td style="padding:7px 6px;font-size:13px;color:#374151;">'+skillNames[k]+'</td>'
      +'<td style="padding:7px 6px;font-size:13px;color:#374151;">Score: <strong>'+scores[k]+'</strong></td>'
      +'<td style="padding:7px 6px;font-size:13px;color:#374151;">'+clbLabel+'</td>'
      +'<td style="padding:7px 6px;font-size:13px;font-weight:800;color:#c40000;text-align:right;">'+{'L':ptsL,'R':ptsR,'W':ptsW,'S':ptsS}[k]+' pts</td></tr>';
  });
  html+='<tr style="background:#fef2f2;"><td colspan="3" style="padding:9px 6px;font-size:14px;font-weight:800;color:#111827;">Total First Language CRS</td>'
    +'<td style="padding:9px 6px;font-size:16px;font-weight:800;color:#c40000;text-align:right;">'+total+' pts</td></tr>'
    +'</table></div>';

  /* Advice block */
  var nextStep='';
  if(minCLB<10){
    var nextCLB=minCLB<9?9:10;
    var nextPts=clbToCRS(nextCLB,marital)*4;
    var gain=nextPts-total;
    nextStep='<div class="info-box blue" style="margin:10px 0 0;">'
      +'<p><strong>💡 Next target:</strong> Improving your lowest skill to CLB '+nextCLB+' would add approximately <strong>+'+gain+' CRS points</strong> (total → '+(total+gain)+'). '
      +(test==='ielts'?'Use the <a href="https://crsscorecalculator.vercel.app/ielts-crs-calculator">IELTS to CRS Calculator</a> to model different scenarios. ':'')
      +'See our <a href="https://crsscorecalculator.vercel.app/how-to-improve-crs-score">CRS improvement strategies guide</a>.</p></div>';
  } else {
    nextStep='<div class="info-box green" style="margin:10px 0 0;"><p><strong>🏆 Maximum language points achieved!</strong> Focus on other CRS factors — <a href="https://crsscorecalculator.vercel.app/blog/crs-score-education">education</a>, <a href="https://crsscorecalculator.vercel.app/blog/crs-score-by-age">age</a>, work experience, or a <a href="https://crsscorecalculator.vercel.app/pnp-crs-calculator">PNP nomination (+600 pts)</a>.</p></div>';
  }
  html+=nextStep;

  var res=document.getElementById('langResult');
  document.getElementById('langResultContent').innerHTML=html;
  res.style.display='block';
  res.scrollIntoView({behavior:'smooth',block:'nearest'});
}

/* ─── CLB BAR CHART ─── */
var clbData=[
  {lbl:'CLB 10+ (IELTS 8.0)',pts:136,pct:100},
  {lbl:'CLB 9  (IELTS 7.0)',pts:124,pct:91},
  {lbl:'CLB 8  (IELTS 6.5)',pts:92, pct:68},
  {lbl:'CLB 7  (IELTS 6.0)',pts:68, pct:50},
  {lbl:'CLB 6  (IELTS 5.5)',pts:36, pct:26},
  {lbl:'CLB 5  (IELTS 5.0)',pts:24, pct:18}
];
var colours=['#c40000','#d42000','#d44000','#c46000','#9e7000','#6b7280'];
var rows='';
clbData.forEach(function(d,i){
  rows+='<div class="cbc-row">'
    +'<div class="cbc-lbl">'+d.lbl+'</div>'
    +'<div class="cbc-bar-wrap"><div class="cbc-bar" style="width:'+d.pct+'%;background:'+colours[i]+';">'+d.pts+'</div></div>'
    +'<div class="cbc-pts">'+d.pts+'</div>'
    +'</div>';
});
document.getElementById('clbBarRows').innerHTML=rows;

/* ─── TAB SYSTEM ─── */
function switchTab(btn,panelId){
  var wrap=btn.closest('.tab-wrap')||btn.parentElement.nextElementSibling;
  var allBtns=btn.parentElement.querySelectorAll('.tab-btn');
  var allPanels=wrap.querySelectorAll('.tab-panel');
  allBtns.forEach(function(b){b.classList.remove('active');});
  allPanels.forEach(function(p){p.classList.remove('active');});
  btn.classList.add('active');
  var panel=document.getElementById('tab-'+panelId);
  if(panel)panel.classList.add('active');
}

/* ─── MOBILE MENU ─── */
var menuBtn=document.getElementById('menuBtn');
var mobileMenu=document.getElementById('mobileMenu');
if(menuBtn&&mobileMenu){
  menuBtn.addEventListener('click',function(){
    var open=mobileMenu.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded',open);
  });
}
</script>

