                      </tr>
                    </thead>
                    <tbody>
                      <tr><td>9.0</td><td class="clb-cell">CLB 10+</td><td class="pts-cell">34</td><td>32</td><td class="pts-cell">136</td></tr>
                      <tr><td>8.5</td><td class="clb-cell">CLB 10+</td><td class="pts-cell">34</td><td>32</td><td class="pts-cell">136</td></tr>
                      <tr><td>8.0</td><td class="clb-cell">CLB 10+</td><td class="pts-cell">34</td><td>32</td><td class="pts-cell">136</td></tr>
                      <tr><td>7.5 (L/R/S) / 7.0 (W)</td><td class="clb-cell">CLB 9</td><td class="pts-cell">31</td><td>29</td><td class="pts-cell">124</td></tr>
                      <tr><td>7.5 (L/R/S) / 6.5 (W)</td><td class="clb-cell">CLB 8 / 9</td><td class="pts-cell">23–31</td><td>22–29</td><td>92–124</td></tr>
                      <tr><td>7.0 (L/R/S) / 6.5 (W)</td><td class="clb-cell">CLB 8</td><td class="pts-cell">23</td><td>22</td><td class="pts-cell">92</td></tr>
                      <tr><td>6.5 (L/R/S)</td><td class="clb-cell">CLB 7–8</td><td class="pts-cell">17–23</td><td>16–22</td><td>68–92</td></tr>
                      <tr><td>6.0 (L/R/S) / 5.5 (W)</td><td class="clb-cell">CLB 7</td><td class="pts-cell">17</td><td>16</td><td class="pts-cell">68</td></tr>
                      <tr><td>5.5 (L/R/S)</td><td class="clb-cell">CLB 6</td><td class="pts-cell">9</td><td>8</td><td class="pts-cell">36</td></tr>
                      <tr><td>5.0 (L/R/S)</td><td class="clb-cell">CLB 5–6</td><td class="pts-cell">6–9</td><td>6–8</td><td>24–36</td></tr>
                      <tr><td>4.0–4.5</td><td class="clb-cell">CLB 4</td><td class="pts-cell">6</td><td>6</td><td class="pts-cell">24</td></tr>
                    </tbody>
                  </table>
                </div>
                <p class="tiny muted" style="padding:10px 0 0;">Note: Exact CLB equivalency per skill depends on skill type. Listening and Reading have different band-to-CLB conversions than Writing and Speaking. See the official <a href="https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/documents/language-requirements/language-testing.html" target="_blank" rel="noopener noreferrer">IRCC IELTS CLB equivalency chart</a>.</p>
