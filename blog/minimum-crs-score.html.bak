                  <tr><td>2016</td><td>457</td><td>N/A</td><td>Pool growth, stabilisation</td></tr>
                  <tr><td>2017</td><td class="green-t">415</td><td>N/A</td><td>Large draws, high immigration targets</td></tr>
                  <tr><td>2018</td><td>440</td><td>N/A</td><td>Tech draws first appeared</td></tr>
                  <tr><td>2019</td><td class="green-t">413 ← All-time low</td><td>N/A</td><td>Record 3,900 invited Nov 2019</td></tr>
                  <tr><td>2020</td><td>431</td><td>N/A</td><td>COVID-19 processing pause</td></tr>
