  <style>
    :root{--primary:#c40000;--primary-dark:#a80000;--text:#1f2937;--muted:#6b7280;--border:#e5e7eb;--bg:#f3f4f6;--card:#ffffff;--shadow:0 2px 8px rgba(0,0,0,.06);--radius:12px;--max:1200px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:Arial,Helvetica,sans-serif;color:var(--text);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased}
    a{color:var(--primary);text-decoration:none}
    a:hover{text-decoration:underline}
    img{max-width:100%;display:block;height:auto}
    .container{max-width:var(--max);margin:auto;padding:0 14px}
    .skip-link{position:absolute;left:-9999px;top:auto}
    .skip-link:focus{left:12px;top:12px;background:#fff;padding:10px 14px;z-index:1000;border-radius:8px}

    .topbar{background:#fff;border-bottom:1px solid #efefef;position:sticky;top:0;z-index:999}
    .nav{display:flex;align-items:center;justify-content:space-between;gap:16px;min-height:58px}
    .brand{display:flex;align-items:center;gap:8px;font-weight:700;color:#111;white-space:nowrap;text-decoration:none}
    .brand-badge{width:24px;height:24px;border-radius:5px;background:var(--primary);display:grid;place-items:center;color:#fff;font-size:12px;font-weight:700}
    .nav-links{display:flex;gap:14px;flex-wrap:wrap;align-items:center;font-size:13px}
    .nav-links a{color:#374151}
    .nav-cta{background:var(--primary);color:#fff !important;padding:8px 12px;border-radius:8px;font-weight:700}
    .nav-cta:hover{background:var(--primary-dark);text-decoration:none}
    .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
    .hamburger span{display:block;width:22px;height:2px;background:#374151;border-radius:2px}
    .mobile-menu{display:none;background:#fff;border-top:1px solid #efefef;padding:10px 14px}
    .mobile-menu a{display:block;padding:10px 0;font-size:14px;color:#374151;border-bottom:1px solid #f5f5f5}
    .mobile-menu.open{display:block}

    .hero{background:linear-gradient(180deg,#c40000 0%,#b20000 100%);color:#fff;padding:34px 0 28px;text-align:center}
    .hero h1{margin:0 auto 8px;font-size:clamp(24px,4vw,40px);line-height:1.15;max-width:900px;font-weight:800}
    .hero p{margin:0 auto 16px;max-width:850px;color:#ffeaea;font-size:15px}
    .pill-row{display:flex;justify-content:center;flex-wrap:wrap;gap:8px;margin:0 0 18px}
    .pill{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:#fff;padding:7px 10px;font-size:12px;border-radius:999px}
    .hero-actions{display:flex;justify-content:center;flex-wrap:wrap;gap:10px}
    .btn{display:inline-flex;align-items:center;gap:8px;border:none;border-radius:10px;padding:12px 18px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none !important;transition:background .18s}
    .btn-white{background:#fff;color:var(--primary)}
    .btn-white:hover{background:#f0f0f0}
    .btn-outline{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.35)}
    .btn-outline:hover{background:rgba(255,255,255,.08)}

    main{padding:18px 0 30px}
    .breadcrumbs{font-size:12px;color:#6b7280;margin:0 0 14px}
    .breadcrumbs a{color:#6b7280}
    .grid{display:grid;grid-template-columns:minmax(0,1.7fr) 310px;gap:18px;align-items:start}

    .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow)}
    .card-head{padding:14px 16px;border-bottom:1px solid var(--border);font-weight:700;font-size:15px;display:flex;align-items:center;gap:8px}
    .card-body{padding:16px}

    .intro-box{background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:14px 16px;margin-bottom:18px}
    .intro-box p{font-size:14px;color:#374151;margin:0;max-width:none}

    .section-label{background:#fff0f0;border:1px solid #ffd4d4;color:#8b0000;font-size:13px;font-weight:700;padding:9px 10px;border-radius:8px;margin:0 0 14px}

    .blog-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
    .post-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:16px;box-shadow:var(--shadow);display:flex;flex-direction:column;gap:10px}
    .post-top{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .post-tag{display:inline-flex;align-items:center;background:#fef2f2;color:var(--primary);border:1px solid #fecaca;border-radius:999px;padding:4px 10px;font-size:11px;font-weight:700}
    .post-read{font-size:12px;color:var(--muted)}
    .post-card h2{font-size:18px;line-height:1.25;color:#111827;font-weight:800}
    .post-card p{font-size:14px;color:#4b5563;margin:0;max-width:100%}
    .post-meta{display:flex;flex-wrap:wrap;gap:8px;font-size:12px;color:#6b7280}
    .mini-pill{background:#f3f4f6;border-radius:999px;padding:4px 8px}
    .post-actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:auto}
    .btn-red,.btn-light{display:inline-flex;align-items:center;justify-content:center;border-radius:9px;padding:10px 14px;font-size:13px;font-weight:700;text-decoration:none !important}
    .btn-red{background:var(--primary);color:#fff}
    .btn-red:hover{background:var(--primary-dark)}
    .btn-light{background:#f9fafb;color:#374151;border:1px solid var(--border)}
    .btn-light:hover{background:#f3f4f6}

    .mini-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:18px}
    .mini-box{background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px;text-align:center}
    .mini-box .val{font-size:24px;font-weight:800;color:var(--primary);line-height:1}
    .mini-box .lbl{font-size:12px;color:var(--muted);margin-top:6px}

    .tool-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .tool{border:1px solid var(--border);border-radius:12px;padding:12px 8px;text-align:center;background:#fff;transition:box-shadow .18s;display:block}
    .tool:hover{box-shadow:0 4px 14px rgba(196,0,0,.1);text-decoration:none}
    .tool-icon{width:32px;height:32px;margin:0 auto 8px;border-radius:999px;background:#fef2f2;color:var(--primary);display:grid;place-items:center;font-weight:700;font-size:11px}
    .tool strong{display:block;font-size:13px;color:#111827}
    .tool span{display:block;font-size:11px;color:#6b7280;margin-top:3px}

    .side-list{display:grid;gap:14px;position:sticky;top:74px}
    .side-card{padding:14px;background:#fff;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow)}
    .side-card h3{margin:0 0 10px;font-size:14px;font-weight:700}
    .side-card ul{list-style:none;padding:0;margin:0}
    .side-card li{padding:8px 0;border-bottom:1px solid #f0f0f0;font-size:13px}
    .side-card li:last-child{border-bottom:none}
    .side-card li a{color:#374151}
    .score-highlight{background:linear-gradient(180deg,#c40000,#ae0000);color:#fff;border-radius:12px;padding:16px;text-align:center}
    .score-highlight .lbl{font-size:12px;color:#ffe4e4;margin-bottom:4px}
    .score-highlight .val{font-size:22px;font-weight:800;margin-bottom:6px}
    .score-highlight .sub{font-size:12px;color:#ffd4d4}
    .cta-link{display:block;margin-top:12px;background:#fff;color:#c40000;border-radius:8px;padding:10px 14px;font-weight:700;font-size:14px;text-decoration:none;text-align:center}

    .faq details{border-bottom:1px solid var(--border);padding:12px 0}
    .faq summary{cursor:pointer;font-weight:700;list-style:none;position:relative;padding-right:24px;font-size:14px;color:#111827}
    .faq summary::-webkit-details-marker{display:none}
    .faq summary::after{content:"+";position:absolute;right:0;top:0;color:var(--primary);font-weight:800;font-size:16px}
    .faq details[open] summary::after{content:"−"}
    .faq p{margin:10px 0 0;color:#4b5563;font-size:14px;max-width:70ch}

    footer{background:#101418;color:#d1d5db;margin-top:28px;padding:30px 0}
    .footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    footer h3{color:#fff;font-size:14px;margin:0 0 10px}
    footer ul{list-style:none;padding:0;margin:0}
    footer li{margin:8px 0;font-size:13px}
    footer a{color:#d1d5db}
    footer a:hover{color:#fff}
    .copyright{margin-top:18px;padding-top:18px;border-top:1px solid rgba(255,255,255,.08);font-size:12px;color:#9ca3af;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}

    @media(max-width:1024px){
      .grid{grid-template-columns:1fr}
      .side-list{position:static}
      .tool-grid{grid-template-columns:repeat(3,1fr)}
      .footer-grid{grid-template-columns:repeat(2,1fr)}
    }
    @media(max-width:720px){
      .nav-links{display:none}
      .hamburger{display:flex}
      .hero{padding:24px 0 20px}
      .blog-grid{grid-template-columns:1fr}
      .mini-grid{grid-template-columns:repeat(2,1fr)}
      .tool-grid{grid-template-columns:repeat(2,1fr)}
      .footer-grid{grid-template-columns:1fr}
      .post-card h2{font-size:17px}
    }
  </style>
</head>
