var TYPE_CLASS={
  'all-programs':'dt-all','cec':'dt-cec','fsw':'dt-fsw','pnp':'dt-pnp',
  'french':'dt-fr','stem':'dt-stem','healthcare':'dt-hc','trades':'dt-tr',
  'transport':'dt-pnp','agriculture':'dt-cec'
};

function renderRows(data){
  var tbody=document.getElementById('drawTableBody');
  var html='';
  data.forEach(function(d){
    var trend=d.score>d.prev?'<span style="color:#15803d;">▲ +'+( d.score-d.prev)+'</span>':d.score<d.prev?'<span style="color:#b91c1c;">▼ '+(d.score-d.prev)+'</span>':'<span style="color:#6b7280;">— same</span>';
    var scoreClass=d.score>=500?'score-high':d.score>=450?'score-mid':'score-low';
    var typeClass=TYPE_CLASS[d.type]||'dt-all';
    var dateStr=new Date(d.date).toLocaleDateString('en-CA',{year:'numeric',month:'short',day:'numeric'});
    html+='<tr data-type="'+d.type+'" data-year="'+d.date.substring(0,4)+'">'
      +'<td><strong>#'+d.num+'</strong></td>'
      +'<td>'+dateStr+'</td>'
      +'<td><span class="draw-type '+typeClass+'">'+d.label+'</span></td>'
      +'<td class="'+scoreClass+'">'+d.score+'</td>'
      +'<td>'+d.inv.toLocaleString()+'</td>'
      +'<td>'+trend+'</td>'
      +'</tr>';
  });
  tbody.innerHTML=html||'<tr><td colspan="6" style="text-align:center;color:#6b7280;padding:20px;">No draws match your filter.</td></tr>';
  document.getElementById('drawCount').textContent=data.length+' draw'+(data.length!==1?'s':'');
}

function filterDraws(){
  var search=document.getElementById('searchDraw').value.toLowerCase();
  var type=document.getElementById('filterType').value;
  var year=document.getElementById('filterYear').value;
  var filtered=DRAWS.filter(function(d){
    var matchSearch=!search||(d.label.toLowerCase().includes(search)||d.date.includes(search)||String(d.score).includes(search));
    var matchType=!type||d.type===type;
    var matchYear=!year||d.date.startsWith(year);
    return matchSearch&&matchType&&matchYear;
  });
  renderRows(filtered);
}

/* Initial render */
renderRows(DRAWS);

/* ─── MOBILE MENU ─── */
var menuBtn=document.getElementById('menuBtn');
var mobileMenu=document.getElementById('mobileMenu');
if(menuBtn&&mobileMenu){
  menuBtn.addEventListener('click',function(){
    var open=mobileMenu.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded',String(open));
  });
}
</script>

