/* Build year cards */
var yg=document.getElementById('yearGrid');
var ycHtml='';
YEARLY.forEach(function(d){
  var colour=d.avg<450?'#c40000':d.avg<490?'#b45309':'#15803d';
  ycHtml+='<div class="year-card">'
    +'<div class="yr">'+d.yr+'</div>'
    +'<div class="range" style="color:'+colour+';">'+d.low+'–'+d.high+'</div>'
    +'<div class="avg">Avg: <strong>'+d.avg+'</strong></div>'
    +'<div class="draws">'+d.draws+' draws</div>'
    +'</div>';
});
yg.innerHTML=ycHtml;

/* Build yearly bar chart */
var colours2=['#6b7280','#6b7280','#15803d','#15803d','#c40000','#b45309','#b91c1c','#b91c1c','#1d4ed8','#1d4ed8','#1d4ed8','#c40000'];
var minAvg=415,maxAvg=568,range2=maxAvg-minAvg;
var br='';
YEARLY.forEach(function(d,i){
  var pct=Math.round((d.avg-minAvg)/range2*100);
  br+='<div class="mc-row">'
    +'<div class="mc-lbl">'+d.yr+'</div>'
    +'<div class="mc-bar-wrap"><div class="mc-bar" style="width:'+pct+'%;background:'+colours2[i]+';min-width:40px;">'+d.avg+'</div></div>'
    +'<div class="mc-val">'+d.avg+'</div>'
    +'</div>';
});
document.getElementById('yearBarRows').innerHTML=br;

