  <style>
    :root{--primary:#c40000;--primary-dark:#a80000;--text:#1f2937;--muted:#6b7280;--border:#e5e7eb;--bg:#f3f4f6;--card:#ffffff;--shadow:0 2px 8px rgba(0,0,0,.06);--radius:12px;--max:1200px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:Arial,Helvetica,sans-serif;color:var(--text);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased}
    a{color:var(--primary);text-decoration:none}
    a:hover{text-decoration:underline}
    img{max-width:100%;display:block;height:auto}
    .container{max-width:var(--max);margin:auto;padding:0 14px}
    .skip-link{position:absolute;left:-9999px;top:auto}
    .skip-link:focus{left:12px;top:12px;background:#fff;padding:10px 14px;z-index:1000;border-radius:8px}

    /* HEADER */
    .topbar{background:#fff;border-bottom:1px solid #efefef;position:sticky;top:0;z-index:999}
    .nav{display:flex;align-items:center;justify-content:space-between;gap:16px;min-height:58px}
    .brand{display:flex;align-items:center;gap:8px;font-weight:700;color:#111;white-space:nowrap;text-decoration:none}
    .brand-badge{width:24px;height:24px;border-radius:5px;background:var(--primary);display:grid;place-items:center;color:#fff;font-size:12px;font-weight:700}
    .nav-links{display:flex;gap:14px;flex-wrap:wrap;align-items:center;font-size:13px}
    .nav-links a{color:#374151}
    .nav-cta{background:var(--primary);color:#fff !important;padding:8px 12px;border-radius:8px;font-weight:700}
    .nav-cta:hover{background:var(--primary-dark);text-decoration:none}
    .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
    .hamburger span{display:block;width:22px;height:2px;background:#374151;border-radius:2px}
    .mobile-menu{display:none;background:#fff;border-top:1px solid #efefef;padding:10px 14px}
    .mobile-menu a{display:block;padding:10px 0;font-size:14px;color:#374151;border-bottom:1px solid #f5f5f5}
    .mobile-menu.open{display:block}

    /* HERO */
    .hero{background:linear-gradient(180deg,#c40000 0%,#b20000 100%);color:#fff;padding:34px 0 28px;text-align:center}
    .hero h1{margin:0 auto 8px;font-size:clamp(22px,4vw,40px);line-height:1.15;max-width:900px;font-weight:800}
    .hero p{margin:0 auto 16px;max-width:860px;color:#ffeaea;font-size:15px}
    .pill-row{display:flex;justify-content:center;flex-wrap:wrap;gap:8px;margin:0 0 18px}
    .pill{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:#fff;padding:7px 10px;font-size:12px;border-radius:999px}
    .hero-actions{display:flex;justify-content:center;flex-wrap:wrap;gap:10px}
    .btn{display:inline-flex;align-items:center;gap:8px;border:none;border-radius:10px;padding:12px 18px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none !important;transition:background .18s}
    .btn-white{background:#fff;color:var(--primary)}
    .btn-white:hover{background:#f0f0f0}
    .btn-outline{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.35)}
    .btn-outline:hover{background:rgba(255,255,255,.08)}
    .btn-red{background:var(--primary);color:#fff}
    .btn-red:hover{background:var(--primary-dark)}

    /* LAYOUT */
    main{padding:18px 0 28px}
    .grid{display:grid;grid-template-columns:minmax(0,1.65fr) 300px;gap:18px;align-items:start}
    .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow)}
    .card-head{padding:14px 16px;border-bottom:1px solid var(--border);font-weight:700;font-size:15px;display:flex;align-items:center;gap:8px}
    .card-body{padding:16px}

    /* ARTICLE META */
    .article-meta{display:flex;flex-wrap:wrap;gap:12px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:16px}
    .article-meta .badge{background:#fef2f2;color:var(--primary);border:1px solid #fecaca;border-radius:999px;padding:3px 10px;font-size:12px;font-weight:700}
    .post-title{font-size:clamp(22px,3vw,30px);font-weight:800;color:#111827;line-height:1.2;margin-bottom:10px}
    .post-lead{font-size:15px;color:#4b5563;line-height:1.65;margin-bottom:16px;max-width:72ch}

    /* TOC */
    .toc{background:#fff8f8;border:1px solid #fecaca;border-radius:12px;padding:16px;margin-bottom:20px}
    .toc h2{font-size:14px;margin-bottom:10px;color:var(--primary);font-weight:700}
    .toc ol{padding-left:18px;margin:0}
    .toc li{padding:4px 0;font-size:13px}
    .toc a{color:#374151}
    .toc a:hover{color:var(--primary)}

    /* INFO BOXES */
    .info-box{border-radius:10px;padding:14px 16px;margin:14px 0}
    .info-box.green{background:#f0fdf4;border:1px solid #bbf7d0}
    .info-box.blue{background:#eff6ff;border:1px solid #bfdbfe}
    .info-box.amber{background:#fffbeb;border:1px solid #fde68a}
    .info-box.red{background:#fff0f0;border:1px solid #fecaca}
    .info-box p{margin:0;font-size:14px;color:#374151;max-width:none}
    .info-box.green strong{color:#166534}
    .info-box.blue strong{color:#1d4ed8}
    .info-box.amber strong{color:#92400e}
    .info-box.red strong{color:#b91c1c}

    /* SECTION LABEL */
    .section-label{background:#fff0f0;border:1px solid #ffd4d4;color:#8b0000;font-size:13px;font-weight:700;padding:9px 10px;border-radius:8px;margin:0 0 14px}

    /* CONTENT */
    .content p{margin:0 0 12px;color:#4b5563;font-size:14px;max-width:75ch}
    .content h2{font-size:20px;font-weight:800;color:#111827;margin:24px 0 10px;line-height:1.2;scroll-margin-top:80px}
    .content h3{font-size:16px;font-weight:700;color:#111827;margin:18px 0 8px}
    .content ul,.content ol{padding-left:20px;margin:0 0 14px}
    .content li{font-size:14px;color:#4b5563;padding:4px 0;max-width:70ch}
    .content strong{color:#111827}

    /* STATS */
    .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:14px 0}
    .stat{background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px 10px;text-align:center}
    .stat .val{font-size:26px;font-weight:800;color:var(--primary);line-height:1}
    .stat .lbl{font-size:12px;color:var(--muted);margin-top:5px}

    /* YEAR CARDS */
    .year-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}
    .year-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px;text-align:center}
    .year-card .yr{font-size:15px;font-weight:800;color:#111827}
    .year-card .range{font-size:22px;font-weight:800;color:var(--primary);margin:4px 0}
    .year-card .avg{font-size:12px;color:var(--muted)}
    .year-card .draws{font-size:11px;color:#6b7280;margin-top:3px}

    /* MINI BAR CHART */
    .mini-chart{background:#fff;border:1px solid var(--border);border-radius:12px;padding:16px;margin:14px 0}
    .mini-chart h4{font-size:14px;font-weight:700;color:#111827;margin-bottom:14px}
    .mc-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
    .mc-lbl{width:38px;font-size:12px;font-weight:700;color:#374151;flex-shrink:0;text-align:right}
    .mc-bar-wrap{flex:1;background:#f3f4f6;border-radius:999px;height:20px;overflow:hidden}
    .mc-bar{height:100%;border-radius:999px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:11px;font-weight:700;color:#fff;min-width:20px}
    .mc-val{width:40px;font-size:12px;font-weight:800;color:var(--primary);text-align:right;flex-shrink:0}

    /* TABLE */
    .table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:12px;margin:14px 0}
    table{width:100%;border-collapse:collapse;background:#fff;min-width:380px}
    th,td{padding:10px 10px;border-bottom:1px solid var(--border);font-size:13px;text-align:left;vertical-align:middle}
    th{background:#b60000;color:#fff;font-size:12px;white-space:nowrap}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#fafafa}
    .green-t{color:#15803d;font-weight:700}
    .orange-t{color:#b45309;font-weight:700}
    .red-t{color:#b91c1c;font-weight:700}
    .blue-t{color:#1d4ed8;font-weight:700}
    .pts-cell{font-weight:800;color:#c40000}
    .draw-type{border-radius:999px;padding:2px 8px;font-size:11px;font-weight:700;white-space:nowrap;display:inline-block}
    .dt-all{background:#fef2f2;color:#c40000;border:1px solid #fecaca}
    .dt-cec{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0}
    .dt-fsw{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
    .dt-pnp{background:#fdf4ff;color:#7e22ce;border:1px solid #e9d5ff}
    .dt-fr{background:#fff7ed;color:#9a3412;border:1px solid #fed7aa}
    .dt-stem{background:#f0f9ff;color:#0369a1;border:1px solid #bae6fd}
    .dt-hc{background:#fdf2f8;color:#9d174d;border:1px solid #fbcfe8}
    .dt-tr{background:#f7fee7;color:#3f6212;border:1px solid #d9f99d}
    .score-high{color:#15803d;font-weight:800}
    .score-mid{color:#b45309;font-weight:800}
    .score-low{color:#c40000;font-weight:800}

    /* SEARCH / FILTER */
    .filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;align-items:center}
    .filter-bar input,.filter-bar select{border:1px solid #d1d5db;border-radius:8px;padding:8px 10px;font-size:13px;background:#fff;min-height:40px}
    .filter-bar input:focus,.filter-bar select:focus{outline:none;border-color:var(--primary)}
    .filter-bar label{font-size:13px;font-weight:700;color:#374151}

    /* CATEGORY CARDS */
    .cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin:14px 0}
    .cat-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px}
    .cat-card h4{font-size:14px;font-weight:700;color:#111827;margin-bottom:6px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .cat-card p{font-size:13px;color:#4b5563;margin:0}
    .cat-badge{border-radius:999px;padding:2px 8px;font-size:11px;font-weight:700}

    /* CTA */
    .cta-box{background:linear-gradient(135deg,#c40000 0%,#9e0000 100%);border-radius:12px;padding:18px;text-align:center;color:#fff;margin:20px 0}
    .cta-box h3{font-size:16px;margin-bottom:8px}
    .cta-box p{font-size:13px;color:#ffeaea;margin-bottom:14px;max-width:100%}

    /* FAQ */
    .faq details{border-bottom:1px solid var(--border);padding:12px 0}
    .faq summary{cursor:pointer;font-weight:700;list-style:none;position:relative;padding-right:24px;font-size:14px;color:#111827}
    .faq summary::-webkit-details-marker{display:none}
    .faq summary::after{content:"+";position:absolute;right:0;top:0;color:var(--primary);font-weight:800;font-size:16px}
    .faq details[open] summary::after{content:"−"}
    .faq p{margin:10px 0 0;color:#4b5563;font-size:14px;max-width:70ch}

    /* TOOL GRID */
    .tool-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .tool{border:1px solid var(--border);border-radius:12px;padding:12px 8px;text-align:center;background:#fff;transition:box-shadow .18s;display:block}
    .tool:hover{box-shadow:0 4px 14px rgba(196,0,0,.1);text-decoration:none}
    .tool-icon{width:32px;height:32px;margin:0 auto 8px;border-radius:999px;background:#fef2f2;color:var(--primary);display:grid;place-items:center;font-weight:700;font-size:11px}
    .tool strong{display:block;font-size:13px;color:#111827}
    .tool span{display:block;font-size:11px;color:#6b7280;margin-top:3px}

    /* BREADCRUMBS */
    .breadcrumbs{font-size:12px;color:#6b7280;margin:0 0 14px}
    .breadcrumbs a{color:#6b7280}

    /* SIDEBAR */
    .side-list{display:grid;gap:14px;position:sticky;top:74px}
    .side-card{padding:14px;background:#fff;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow)}
    .side-card h3{margin:0 0 10px;font-size:14px;font-weight:700}
    .side-card ul{list-style:none;padding:0;margin:0}
    .side-card li{padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:13px;display:flex;justify-content:space-between;align-items:center;gap:8px}
    .side-card li:last-child{border-bottom:none}
    .side-card li a{color:#374151;font-size:13px}
    .side-pts{background:#fef2f2;color:var(--primary);border-radius:999px;padding:2px 8px;font-size:11px;font-weight:700;white-space:nowrap}
    .score-highlight{background:linear-gradient(180deg,#c40000,#ae0000);color:#fff;border-radius:12px;padding:16px;text-align:center}
    .score-highlight .lbl{font-size:12px;color:#ffe4e4;margin-bottom:4px}
    .score-highlight .val{font-size:22px;font-weight:800;margin-bottom:6px}
    .score-highlight .sub{font-size:12px;color:#ffd4d4}
    .tiny{font-size:12px}
    .muted{color:var(--muted)}

    /* FOOTER */
    footer{background:#101418;color:#d1d5db;margin-top:28px;padding:30px 0}
    .footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    footer h3{color:#fff;font-size:14px;margin:0 0 10px}
    footer ul{list-style:none;padding:0;margin:0}
    footer li{margin:8px 0;font-size:13px}
    footer a{color:#d1d5db}
    footer a:hover{color:#fff}
    .copyright{margin-top:18px;padding-top:18px;border-top:1px solid rgba(255,255,255,.08);font-size:12px;color:#9ca3af;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}

    /* RESPONSIVE */
    @media(max-width:1024px){.grid{grid-template-columns:1fr}.side-list{position:static}.tool-grid{grid-template-columns:repeat(3,1fr)}.footer-grid{grid-template-columns:repeat(2,1fr)}.stat-grid{grid-template-columns:repeat(2,1fr)}.year-grid{grid-template-columns:repeat(3,1fr)}.cat-grid{grid-template-columns:1fr}}
    @media(max-width:680px){.nav-links{display:none}.hamburger{display:flex}.hero{padding:24px 0 20px}.tool-grid{grid-template-columns:repeat(2,1fr)}.footer-grid{grid-template-columns:1fr}th,td{font-size:12px;padding:8px 7px}.content h2{font-size:18px}.stat-grid{grid-template-columns:repeat(2,1fr)}.year-grid{grid-template-columns:repeat(2,1fr)}.filter-bar{flex-direction:column}.filter-bar input,.filter-bar select{width:100%}}
  </style>
</head>
