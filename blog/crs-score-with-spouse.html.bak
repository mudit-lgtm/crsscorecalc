<!-- ══ JAVASCRIPT ══ -->
<script>
/* ─── CRS DATA TABLES ─── */
var AGE_SINGLE={0:0,99:99,105:105,110:110,94:94,88:88,83:83,77:77,72:72,66:66,61:61,55:55,50:50,39:39,28:28,17:17,6:6};
var AGE_SPOUSE_MAP={110:100,105:95,99:90,94:85,88:80,83:75,77:70,72:65,66:60,61:55,55:50,50:45,39:35,28:25,17:15,6:5,0:0};

var EDU_SINGLE={0:0,30:30,90:90,98:98,120:120,128:128,135:135,150:150};
var EDU_SPOUSE={0:0,30:28,90:84,98:91,120:112,128:119,135:126,150:140};

var LANG_CLB_SINGLE={4:6,5:6,6:9,7:17,8:23,9:31,10:34};
var LANG_CLB_SPOUSE={4:6,5:6,6:8,7:16,8:22,9:29,10:32};

var CAN_EXP_SINGLE={0:0,40:40,53:53,64:64,72:72,80:80};
var CAN_EXP_SPOUSE={0:0,40:35,53:46,64:56,72:63,80:70};

function calcSpouse(){
  var ageVal=parseInt(document.getElementById('yourAge').value)||0;
  var eduVal=parseInt(document.getElementById('yourEdu').value)||0;
  var clbVal=parseInt(document.getElementById('yourLang').value)||4;
  var canExpVal=parseInt(document.getElementById('yourCanExp').value)||0;
  var spouseLang=parseInt(document.getElementById('spouseLang').value);
  var spouseEdu=parseInt(document.getElementById('spouseEdu').value)||0;
  var spouseWork=parseInt(document.getElementById('spouseWork').value)||0;
  var adaptability=parseInt(document.getElementById('hasAdaptability').value)||0;

  if(isNaN(spouseLang)||spouseLang===-1) spouseLang=0;

  /* WITHOUT SPOUSE calculation */
  var ageNoSpouse=ageVal;
  var eduNoSpouse=EDU_SINGLE[eduVal]||0;
  var langNoSpouse=(LANG_CLB_SINGLE[Math.min(clbVal,10)]||6)*4;
  var canExpNoSpouse=canExpVal;
  var totalNoSpouse=ageNoSpouse+eduNoSpouse+langNoSpouse+canExpNoSpouse+adaptability;

  /* WITH SPOUSE calculation */
  var ageWithSpouse=AGE_SPOUSE_MAP[ageVal]!==undefined?AGE_SPOUSE_MAP[ageVal]:Math.round(ageVal*0.91);
  var eduWithSpouse=EDU_SPOUSE[eduVal]||0;
  var langClbCapped=Math.min(clbVal,10);
  var langWithSpouse=(LANG_CLB_SPOUSE[langClbCapped]||6)*4;
  var canExpWithSpouse=CAN_EXP_SPOUSE[canExpVal]!==undefined?CAN_EXP_SPOUSE[canExpVal]:Math.round(canExpVal*0.875);
  var spouseBonus=Math.min(40,spouseLang+spouseEdu+spouseWork);
  var totalWithSpouse=ageWithSpouse+eduWithSpouse+langWithSpouse+canExpWithSpouse+spouseBonus+adaptability;

  var diff=totalWithSpouse-totalNoSpouse;
  var diffLabel=diff>0?'+'+diff+' pts advantage with spouse':diff===0?'Equal score either way':Math.abs(diff)+' pts lower with spouse';
  var diffColor=diff>0?'#166534':diff===0?'#374151':'#b91c1c';
  var advice='';

  if(diff<-10){
    advice='<div class="info-box amber" style="margin-top:12px;"><p><strong>💡 Advice:</strong> Your spouse\'s current credentials significantly reduce your CRS. Consider: (1) having your spouse take IELTS/CELPIP to achieve CLB 7+ (adds 16+ pts), (2) having your spouse get an ECA for their education (adds 6–10 pts), or (3) targeting a <a href="https://crsscorecalculator.vercel.app/pnp-crs-calculator">PNP nomination</a> (+600 pts) to offset the difference.</p></div>';
  } else if(diff>5){
    advice='<div class="info-box green" style="margin-top:12px;"><p><strong>✅ Your spouse\'s credentials add value!</strong> Including your spouse in the Express Entry application improves your CRS by '+diff+' points. Ensure all credentials are properly documented — language test results (valid 2 years), ECA for foreign education, and proof of Canadian work experience. Use the <a href="https://crsscorecalculator.vercel.app/">full CRS Calculator</a> to verify your complete score.</p></div>';
  } else {
    advice='<div class="info-box blue" style="margin-top:12px;"><p><strong>📊 Scores are close.</strong> Including or excluding your spouse makes a small difference. Check if your spouse can improve their language score — going from CLB 7–8 to CLB 9+ adds 4 more bonus points (16 → 20 pts). See the <a href="https://crsscorecalculator.vercel.app/blog/crs-score-language-test">language test guide</a>.</p></div>';
  }

  var html=''
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">'

    /* Without spouse card */
    +'<div style="background:#fff8f8;border:1px solid #fecaca;border-radius:12px;padding:14px;text-align:center;">'
    +'<div style="font-size:12px;font-weight:700;color:#6b7280;margin-bottom:6px;">WITHOUT SPOUSE</div>'
    +'<div style="font-size:40px;font-weight:800;color:#c40000;line-height:1;">'+totalNoSpouse+'</div>'
    +'<div style="font-size:12px;color:#374151;margin-top:6px;">CRS Score (estimate)</div>'
    +'<div style="background:#f3f4f6;border-radius:999px;height:6px;margin:10px 0;overflow:hidden;">'
    +'<div style="width:'+Math.min(100,Math.round(totalNoSpouse/600*100))+'%;height:6px;border-radius:999px;background:linear-gradient(90deg,#c40000,#ff4444);"></div></div>'
    +'<div style="font-size:11px;color:#6b7280;">Age: '+ageNoSpouse+' | Edu: '+eduNoSpouse+' | Lang: '+langNoSpouse+' | Work: '+canExpNoSpouse+'</div>'
    +'</div>'

    /* With spouse card */
    +'<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:14px;text-align:center;">'
    +'<div style="font-size:12px;font-weight:700;color:#6b7280;margin-bottom:6px;">WITH SPOUSE</div>'
    +'<div style="font-size:40px;font-weight:800;color:#1d4ed8;line-height:1;">'+totalWithSpouse+'</div>'
    +'<div style="font-size:12px;color:#374151;margin-top:6px;">CRS Score (estimate)</div>'
    +'<div style="background:#f3f4f6;border-radius:999px;height:6px;margin:10px 0;overflow:hidden;">'
    +'<div style="width:'+Math.min(100,Math.round(totalWithSpouse/600*100))+'%;height:6px;border-radius:999px;background:linear-gradient(90deg,#1d4ed8,#60a5fa);"></div></div>'
    +'<div style="font-size:11px;color:#6b7280;">Age: '+ageWithSpouse+' | Edu: '+eduWithSpouse+' | Lang: '+langWithSpouse+' | Spouse: +'+spouseBonus+'</div>'
    +'</div></div>'

    /* Difference banner */
    +'<div style="background:#f9f9f9;border:1px solid #e5e7eb;border-radius:10px;padding:12px;text-align:center;margin-bottom:10px;">'
    +'<span style="font-size:14px;font-weight:700;color:'+diffColor+';">'+diffLabel+'</span>'
    +'</div>'

    /* Spouse breakdown */
    +'<div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:14px;margin-bottom:6px;">'
    +'<div style="font-size:13px;font-weight:700;color:#111827;margin-bottom:10px;">👫 Spouse Bonus Breakdown</div>'
    +'<table style="width:100%;border-collapse:collapse;">'
    +'<tr style="border-bottom:1px solid #f0f0f0;"><td style="padding:6px;font-size:13px;color:#374151;">Spouse Language</td><td style="padding:6px;font-size:13px;font-weight:800;color:#1d4ed8;text-align:right;">+'+spouseLang+' pts</td></tr>'
    +'<tr style="border-bottom:1px solid #f0f0f0;"><td style="padding:6px;font-size:13px;color:#374151;">Spouse Education</td><td style="padding:6px;font-size:13px;font-weight:800;color:#1d4ed8;text-align:right;">+'+spouseEdu+' pts</td></tr>'
    +'<tr style="border-bottom:1px solid #f0f0f0;"><td style="padding:6px;font-size:13px;color:#374151;">Spouse Canadian Work Exp</td><td style="padding:6px;font-size:13px;font-weight:800;color:#1d4ed8;text-align:right;">+'+spouseWork+' pts</td></tr>'
    +'<tr style="background:#eff6ff;"><td style="padding:8px 6px;font-size:14px;font-weight:800;color:#111827;">Total Spouse Bonus</td><td style="padding:8px 6px;font-size:16px;font-weight:800;color:#1d4ed8;text-align:right;">+'+spouseBonus+' / 40 pts</td></tr>'
    +'</table></div>'
    +advice;

  document.getElementById('spouseResultContent').innerHTML=html;
  var res=document.getElementById('spouseResult');
  res.style.display='block';
  res.scrollIntoView({behavior:'smooth',block:'nearest'});
}

/* ─── MOBILE MENU ─── */
var menuBtn=document.getElementById('menuBtn');
var mobileMenu=document.getElementById('mobileMenu');
if(menuBtn&&mobileMenu){
  menuBtn.addEventListener('click',function(){
    var open=mobileMenu.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded',String(open));
  });
}
</script>

<!-- ══ SCHEMA MARKUP ══ -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse#article",
      "headline": "CRS Score with Spouse 2026 – Canada Express Entry Points for Married Couples",
      "description": "Complete 2026 guide to CRS Express Entry points for married and common-law couples. Spouse vs no-spouse comparison, spouse language/education/work experience bonus tables, and interactive calculator.",
      "datePublished": "2026-01-01T00:00:00+00:00",
      "dateModified": "2026-04-19T00:00:00+00:00",
      "url": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse",
      "author": {"@type":"Organization","name":"CRS Calculator","url":"https://crsscorecalculator.vercel.app/"},
      "publisher": {
        "@type": "Organization",
        "name": "CRS Calculator",
        "url": "https://crsscorecalculator.vercel.app/",
        "logo": {"@type":"ImageObject","url":"https://crsscorecalculator.vercel.app/og-image.jpg"}
      },
      "mainEntityOfPage": {"@type":"WebPage","@id":"https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse"},
      "image": "https://crsscorecalculator.vercel.app/og-image.jpg",
      "inLanguage": "en-CA"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does having a spouse always lower your CRS score?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Not necessarily. Having a spouse lowers your core language, education, and age points by up to 40 total — but your spouse's language proficiency, education, and Canadian work experience add up to 40 bonus points. If your spouse has CLB 9+ language + a post-secondary degree + Canadian work experience, the net effect on your CRS score is neutral or positive."
          }
        },
        {
          "@type": "Question",
          "name": "What is the maximum CRS bonus from a spouse?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The maximum spouse factor bonus is 40 CRS points: 20 pts for spouse language (CLB 9+ in all 4 skills) + 10 pts for spouse education (Master's or PhD) + 10 pts for spouse Canadian work experience (5+ years)."
          }
        },
        {
          "@type": "Question",
          "name": "Does my spouse need to take a language test for Express Entry?",
          "acceptedAnswer": {
            "@type": "Answer",
                        "text": "Your spouse is not required to take a language test, but taking one and achieving CLB 5 or higher adds 6–20 CRS bonus points to your profile. Even CLB 7–8 adds 16 points. Not submitting a spouse language test result means 0 spouse language points — leaving up to 20 CRS points unclaimed."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if my spouse is already a Canadian PR or citizen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If your spouse is already a Canadian permanent resident or citizen, you are scored on the without-spouse grid — you receive the higher core scores and do not list them as an accompanying spouse. You also receive additional adaptability points for having a spouse or common-law partner in Canada as a citizen or PR."
          }
        },
        {
          "@type": "Question",
          "name": "Does common-law partner count the same as spouse for CRS?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. For CRS scoring purposes, a common-law partner of 12+ months cohabitation is treated identically to a legal spouse. The with-spouse grid applies, and your partner's language, education, and Canadian work experience all contribute the same bonus points as a legal spouse's credentials."
          }
        },
        {
          "@type": "Question",
          "name": "Which language tests can my spouse take for the CRS bonus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Your spouse can take any of the four IRCC-accepted language tests: IELTS General Training (English), CELPIP-General (English), TEF Canada (French), or TCF Canada (French). Test results must be within 2 years of the test date."
          }
        },
        {
          "@type": "Question",
          "name": "Does my spouse's foreign work experience count for CRS bonus points?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Only your spouse's Canadian work experience in a skilled occupation (NOC Skill Type 0, A, or B) earns CRS bonus points. Foreign work experience does not count toward the spouse factors bonus."
          }
        },
        {
          "@type": "Question",
          "name": "Can I switch from with-spouse to without-spouse in my Express Entry profile?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can update your Express Entry profile before receiving an ITA (Invitation to Apply). Changing your marital status or whether your spouse accompanies you will immediately recalculate your CRS score. Consult a Regulated Canadian Immigration Consultant (RCIC) before making this change, as it has legal implications."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://crsscorecalculator.vercel.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "CRS Score",
          "item": "https://crsscorecalculator.vercel.app/what-is-crs-score"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "CRS Score with Spouse 2026",
          "item": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse"
        }
      ]
    },
    {
      "@type": "WebApplication",
      "@id": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse#tool",
      "name": "CRS Score with Spouse Calculator",
      "description": "Interactive tool to compare CRS Express Entry points with and without an accompanying spouse or common-law partner. Calculates spouse language, education, and Canadian work experience bonus points for 2026.",
      "url": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse#spouse-checker",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Web Browser",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "CAD"
      }
    },
    {
      "@type": "HowTo",
      "name": "How to Calculate CRS Score with Spouse for Canada Express Entry",
      "description": "Step-by-step guide to calculating your CRS score when applying with an accompanying spouse or common-law partner.",
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Determine your marital status for CRS purposes",
          "text": "The with-spouse grid applies when your spouse is not a Canadian PR or citizen AND will accompany you to Canada. If your spouse is already a Canadian PR or citizen, use the without-spouse grid."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Calculate your core factors using the with-spouse grid",
          "text": "Use the with-spouse CRS grid for your age, education, language, and Canadian work experience. These are slightly lower than the without-spouse grid — e.g. CLB 10 earns 32 pts/skill instead of 34 pts/skill."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Have your spouse take a language test",
          "text": "Your spouse should take IELTS General Training, CELPIP-General, TEF Canada, or TCF Canada. CLB 9+ in all 4 skills adds 20 CRS bonus points to your profile. CLB 7–8 adds 16 pts."
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "Include your spouse's education credential",
          "text": "Get an ECA for your spouse's foreign degree from a designated organisation. A Master's or PhD adds 10 CRS bonus points. A Bachelor's adds 8 pts. Submit the ECA with your Express Entry profile."
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "Add spouse Canadian work experience if applicable",
          "text": "If your spouse has worked in Canada in a skilled NOC 0/A/B occupation, include it in your profile. 1 year = 5 pts, 2 years = 7 pts, 5+ years = 10 pts. Maximum 10 pts."
        },
        {
          "@type": "HowToStep",
          "position": 6,
          "name": "Total your CRS score",
          "text": "Add your core factors + spouse bonus factors + skill transferability + adaptability + any bonus points (PNP nomination, job offer). Use the free CRS Calculator at crsscorecalculator.vercel.app for your complete score."
        }
      ]
    },
    {
      "@type": "Table",
      "about": "CRS Score with Spouse vs Without Spouse Comparison 2026",
      "description": "Official IRCC CRS points comparison: with spouse max core = 460 pts + 40 spouse bonus = 500 pts total. Without spouse max core = 500 pts. Spouse language max 20 pts (CLB 9+), education max 10 pts (PhD/Master's), Canadian work experience max 10 pts (5+ years)."
    },
    {
      "@type": "WebPage",
      "@id": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse",
      "name": "CRS Score with Spouse 2026 – Express Entry Points for Married Couples",
      "description": "Complete guide to CRS Express Entry points for married couples 2026. With-spouse vs without-spouse comparison, all spouse bonus point tables, and interactive calculator.",
      "url": "https://crsscorecalculator.vercel.app/blog/crs-score-with-spouse",
      "inLanguage": "en-CA",
      "isPartOf": {
        "@type": "WebSite",
        "name": "CRS Calculator",
        "url": "https://crsscorecalculator.vercel.app/"
      },
      "about": [
        {"@type": "Thing", "name": "CRS Score with Spouse"},
        {"@type": "Thing", "name": "Express Entry Married Couple CRS"},
        {"@type": "Thing", "name": "Canada Immigration Spouse Points"}
      ],
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".post-lead", ".info-box.blue", ".faq"]
      }
    }
  ]
}
</script>

</body>
