              <div class="stat"><div class="val">1,200</div><div class="lbl">Maximum CRS Points</div></div>
              <div class="stat"><div class="val">500</div><div class="lbl">Core Human Capital Max</div></div>
              <div class="stat"><div class="val">600</div><div class="lbl">PNP Nomination Bonus</div></div>
