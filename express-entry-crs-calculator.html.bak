  <!-- ═══ JAVASCRIPT ═══ -->
  <script>
    /* ── NAV TOGGLE ── */
    function toggleNav(btn) {
      const nav = document.getElementById('navLinks');
      const open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', open);
    }

    /* ── SECTION COLLAPSE ── */
    function toggleSection(header) {
      const body = header.nextElementSibling;
      const isCollapsed = header.classList.toggle('collapsed');
      if (body && body.classList.contains('section-body')) {
        body.style.display = isCollapsed ? 'none' : '';
      }
      header.setAttribute('aria-expanded', !isCollapsed);
    }

    /* ── SPOUSE TOGGLE ── */
    function toggleSpouse(cb) {
      document.getElementById('spouseFields').style.display = cb.checked ? 'block' : 'none';
    }

    /* ── LANG HINTS ── */
    function updateLangHints() {
      const t = document.getElementById('langTest').value;
      const hints = {
        ielts: 'IELTS band 0–9 (e.g. 7.5)',
        celpip: 'CELPIP level 1–12 (e.g. 9)',
        tef: 'TEF raw score (e.g. 263)',
        tcf: 'TCF score (e.g. 549)'
      };
      const h = document.getElementById('ls-hint');
      if (h) h.textContent = hints[t] || '';
    }

    /* ── IELTS → CLB → CRS POINTS ── */
    function ieltsToClb(score) {
      if (score >= 8.5) return 12;
      if (score >= 8.0) return 10;
      if (score >= 7.5) return 9;  // CLB 9 for listening/reading at 8.5/7.5
      if (score >= 7.0) return 9;
      if (score >= 6.5) return 8;
      if (score >= 6.0) return 7;
      if (score >= 5.5) return 6;
      if (score >= 5.0) return 5;
      if (score >= 4.0) return 4;
      return 3;
    }
    // Slightly different thresholds per skill for accuracy
    function ieltsToClbBySkill(score, skill) {
      const maps = {
        listening: [[8.5,12],[8.0,10],[7.5,9],[6.0,8],[5.5,7],[5.0,6],[4.5,5],[4.0,4]],
        reading:   [[8.5,12],[8.0,10],[7.0,9],[6.5,8],[6.0,7],[5.0,6],[4.0,5],[3.5,4]],
        writing:   [[7.5,12],[7.0,10],[6.5,9],[6.0,8],[5.5,7],[5.0,6],[4.0,5],[3.5,4]],
        speaking:  [[7.5,12],[7.0,10],[6.5,9],[6.0,8],[5.5,7],[5.0,6],[4.0,5],[3.5,4]]
      };
      const map = maps[skill] || maps.reading;
      for (const [threshold, clb] of map) {
        if (score >= threshold) return clb;
      }
      return 3;
    }

    function clbToCrsPoints(clb, isFirst, hasSpouse) {
      // Single applicant, first language points per skill
      const single1st = { 3:0,4:6,5:6,6:9,7:17,8:23,9:31,10:34,11:34,12:34 };
      const coupled1st = { 3:0,4:6,5:6,6:8,7:16,8:22,9:29,10:32,11:32,12:32 };
      const single2nd = { 3:0,4:0,5:1,6:1,7:3,8:3,9:6,10:6,11:6,12:6 };
      const table = hasSpouse ? coupled1st : (isFirst ? single1st : single2nd);
      return table[Math.min(clb, 12)] || 0;
    }

    /* ── MAIN CALCULATE FUNCTION ── */
    function calculateCRS() {
      const hasSpouse = document.getElementById('spouseToggle').checked;

      // Section A
      const ageScore = parseInt(document.getElementById('age').value) || 0;
      const eduScore = parseInt(document.getElementById('education').value) || 0;
      const canExpScore = parseInt(document.getElementById('canadaExp').value) || 0;
      const sectionA_base = ageScore + eduScore + canExpScore;

      // Language
      const testType = document.getElementById('langTest').value;
      const lsVal = parseFloat(document.getElementById('ls').value) || 0;
      const rsVal = parseFloat(document.getElementById('rs').value) || 0;
      const wsVal = parseFloat(document.getElementById('ws').value) || 0;
      const ssVal = parseFloat(document.getElementById('ss').value) || 0;

      let langScore = 0;
      if (testType === 'ielts' || testType === 'celpip') {
        const clbL = ieltsToClbBySkill(lsVal, 'listening');
        const clbR = ieltsToClbBySkill(rsVal, 'reading');
        const clbW = ieltsToClbBySkill(wsVal, 'writing');
        const clbS = ieltsToClbBySkill(ssVal, 'speaking');
        langScore = clbToCrsPoints(clbL,'first',hasSpouse) +
                    clbToCrsPoints(clbR,'first',hasSpouse) +
                    clbToCrsPoints(clbW,'first',hasSpouse) +
                    clbToCrsPoints(clbS,'first',hasSpouse);
      } else {
        // TEF/TCF — simplified (CLB from raw, approximate)
        const avgScore = (lsVal + rsVal + wsVal + ssVal) / 4;
        const approxClb = Math.min(12, Math.max(3, Math.round(avgScore / 100 * 6 + 4)));
        langScore = clbToCrsPoints(approxClb,'first',hasSpouse) * 4;
      }
      const sectionA = sectionA_base + langScore;

      // Section B (Spouse)
      let sectionB = 0;
      if (hasSpouse) {
        sectionB += parseInt(document.getElementById('spouseEdu').value) || 0;
        sectionB += parseInt(document.getElementById('spouseCanExp').value) || 0;
        // Spouse lang simplified bonus
        sectionB = Math.min(sectionB, 40);
      }

      // Section C – Skill Transferability (simplified but accurate for common profiles)
      const foreignExp = parseInt(document.getElementById('foreignExp').value) || 0;
      let sectionC = 0;
      // Education + language combo
      if (langScore >= 60 && eduScore >= 112) sectionC += 25; else if (langScore >= 50 && eduScore >= 84) sectionC += 13;
      // Foreign work + Canadian work
      if (foreignExp > 0 && canExpScore > 0) sectionC += foreignExp === 25 ? 25 : 13;
      // Foreign work + language
      if (foreignExp > 0 && langScore >= 60) sectionC += foreignExp === 25 ? 25 : 13;
      sectionC = Math.min(sectionC, 100);

      // Section D – Additional
      const pnpPts = parseInt(document.getElementById('pnp').value) || 0;
      const jobPts = parseInt(document.getElementById('jobOffer').value) || 0;
      const eduCanPts = parseInt(document.getElementById('canadaEdu').value) || 0;
      const siblingPts = parseInt(document.getElementById('sibling').value) || 0;
      const frenchPts = parseInt(document.getElementById('frenchBonus').value) || 0;
      const sectionD = pnpPts + jobPts + eduCanPts + siblingPts + frenchPts;

      const total = Math.min(1200, sectionA + sectionB + sectionC + sectionD);

      // Display result
      displayResult(total, {
        'Section A – Core Human Capital': { pts: sectionA, max: hasSpouse ? 460 : 500 },
        'Section B – Spouse / Partner': { pts: sectionB, max: 40 },
        'Section C – Skill Transferability': { pts: sectionC, max: 100 },
        'Section D – Additional Points': { pts: sectionD, max: 600 }
      });
    }

    function displayResult(total, breakdown) {
      document.getElementById('totalScore').textContent = total.toLocaleString();

      let verdict, verdictClass;
      if (total >= 500) { verdict = '🏆 Excellent'; verdictClass = 'high'; }
      else if (total >= 471) { verdict = '✅ Competitive'; verdictClass = 'good'; }
      else if (total >= 440) { verdict = '⚠️ Moderate'; verdictClass = 'mod'; }
      else { verdict = '📈 Needs Boost'; verdictClass = 'low'; }
      document.getElementById('verdict').textContent = verdict;

      // Result box colour based on score
      const rb = document.querySelector('.result-box');
      rb.style.borderColor = total >= 470 ? 'var(--green)' : total >= 440 ? 'var(--orange)' : 'var(--red)';
      document.querySelector('.result-header').style.background = total >= 470 ? 'var(--green)' : total >= 440 ? 'var(--orange)' : 'var(--red)';

      // Breakdown rows
      const container = document.getElementById('breakdownRows');
      container.innerHTML = '';
      Object.entries(breakdown).forEach(([label, {pts, max}]) => {
        const pct = max > 0 ? Math.min(100, (pts / max) * 100) : 0;
        const row = document.createElement('div');
        row.className = 'br-row';
        row.innerHTML = `
          <span class="br-label">${label}</span>
          <div class="br-bar-wrap"><div class="br-bar" style="width:${pct}%"></div></div>
          <span class="br-pts">${pts} / ${max}</span>
        `;
        container.appendChild(row);
      });

      // Tips
      const tips = [];
      const ieltsAvg = ((parseFloat(document.getElementById('ls').value)||0) +
                        (parseFloat(document.getElementById('rs').value)||0) +
                        (parseFloat(document.getElementById('ws').value)||0) +
                        (parseFloat(document.getElementById('ss').value)||0)) / 4;
      if (ieltsAvg < 7.0) tips.push('Improve IELTS/CELPIP to CLB 9+ (≈ IELTS 7.0) — language is the highest single factor in CRS.');
      if (parseInt(document.getElementById('pnp').value) === 0) tips.push('Apply for a <a href="/pnp-crs-calculator">Provincial Nomination (PNP)</a> — it adds 600 instant points and virtually guarantees an ITA.');
      if (parseInt(document.getElementById('jobOffer').value) === 0) tips.push('A valid LMIA job offer can add 50–200 CRS points.');
      if (parseInt(document.getElementById('frenchBonus').value) === 0) tips.push('Learning French (NCLC 7+) adds 25–50 CRS bonus points and opens French-language draws with lower cutoffs.');
      if (parseInt(document.getElementById('canadaExp').value) === 0) tips.push('Any Canadian work experience adds CRS points and may open the CEC stream.');

      const tipsBox = document.getElementById('tipsBox');
      if (tips.length > 0) {
        tipsBox.innerHTML = `<h3>💡 Ways to Improve Your Score</h3><ul>${tips.map(t=>`<li>${t}</li>`).join('')}</ul>`;
        tipsBox.style.display = 'block';
      } else {
        tipsBox.innerHTML = `<h3>🎉 Great Score!</h3><p>Your score of ${total} is competitive. Monitor <a href="/express-entry-draw-history">draw cutoffs</a> and submit your profile when ready.</p>`;
        tipsBox.style.display = 'block';
      }

      const resultEl = document.getElementById('result');
      resultEl.style.display = 'block';
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function resetCalc() {
      document.getElementById('result').style.display = 'none';
      document.querySelector('.calc-card').scrollIntoView({ behavior: 'smooth' });
    }

    function shareResult() {
      const score = document.getElementById('totalScore').textContent;
      const text = `My Express Entry CRS score estimate: ${score}/1200 — calculated with https://crsscorecalculator.vercel.app/express-entry-crs-calculator`;
      if (navigator.share) {
        navigator.share({ title: 'My CRS Score', text, url: window.location.href }).catch(()=>{});
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(() => alert('Score copied to clipboard!'));
      }
    }

    /* ── FAQ ACCORDION ── */
    function toggleFaq(btn) {
      const item = btn.parentElement;
      const wasOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-q').setAttribute('aria-expanded','false');
      });
      if (!wasOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded','true');
      }
    }

    /* ── SECTION HEADER KEYBOARD SUPPORT ── */
    document.querySelectorAll('.section-header').forEach(h => {
      h.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleSection(h); }});
    });

    /* ── DRAWS DATA (static fallback, replace with API if available) ── */
    const drawData = [
      { draw: '320', type: 'All Program', crs: '522' },
      { draw: '319', type: 'Healthcare', crs: '431' },
      { draw: '318', type: 'French Lang.', crs: '379' },
      { draw: '317', type: 'All Program', crs: '518' },
    ];
    const tbody = document.getElementById('drawsBody');
    if (tbody) {
      tbody.innerHTML = drawData.map(d =>
        `<tr><td>#${d.draw}</td><td>${d.type}</td><td><strong>${d.crs}</strong></td></tr>`
      ).join('');
    }
  </script>

</body>
</html>
