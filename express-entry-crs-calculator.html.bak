            "@type": "HowToStep",
            "position": 1,
            "name": "Enter Personal & Education Details",
            "text": "Select your age, marital status, and highest education level. If applying with a spouse, toggle spouse inclusion and add their details.",
            "url": "https://crsscorecalculator.vercel.app/express-entry-crs-calculator#section-a"
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Add Language Test Scores",
            "text": "Choose your test type (IELTS, CELPIP, TEF Canada, or TCF Canada) and enter scores for speaking, listening, reading, and writing.",
            "url": "https://crsscorecalculator.vercel.app/express-entry-crs-calculator#section-language"
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Enter Work Experience",
            "text": "Input years of Canadian and foreign skilled work experience. Foreign work experience contributes to skill transferability points.",
            "url": "https://crsscorecalculator.vercel.app/express-entry-crs-calculator#section-work"
          },
          {
            "@type": "HowToStep",
            "position": 4,
