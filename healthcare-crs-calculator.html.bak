    "description": "Free CRS Score Calculator for Canadian healthcare workers. Calculate Express Entry points for nurses, doctors, pharmacists and all healthcare NOC occupations. Updated for 2026 category-based draws.",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" },
    "publisher": {
      "@type": "Organization",
      "name": "CRS Score Calculator",
      "url": "https://crsscorecalculator.vercel.app",
