  <!-- CALCULATOR -->
  <main id="calculator">
    <div class="calc-card">
      <div class="calc-header">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        <h2>Healthcare Workers CRS Calculator 2026 — Express Entry Score Tool</h2>
      </div>
      <div class="calc-body">

        <!-- Healthcare NOC Selection -->
        <span class="section-label">Step 1 — Your Healthcare NOC Code</span>
        <div class="noc-box">
          <strong>Select your healthcare occupation to check category-based draw eligibility:</strong>
          <p style="margin:0;font-size:0.8rem;color:var(--text-muted);">Healthcare category draws use IRCC's <a href="https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/submit-profile/rounds-invitations/category-based-selection.html" target="_blank" rel="noopener noreferrer">target occupations list</a>. Confirm your NOC via the <a href="https://noc.esdc.gc.ca/" target="_blank" rel="noopener noreferrer">ESDC NOC Search</a>.</p>
        </div>
        <div class="form-grid">
          <div class="form-group" style="grid-column:1/-1;">
            <label for="healthcareNOC">Healthcare Occupation (NOC Code)</label>
            <select id="healthcareNOC">
              <option value="eligible">— Select your occupation —</option>
              <optgroup label="Physicians &amp; Dentists (TEER 1)">
                <option value="eligible">31100 — Specialist physicians (e.g., cardiologist, surgeon)</option>
                <option value="eligible">31102 — General practitioners &amp; family physicians</option>
                <option value="eligible">31103 — Dentists</option>
                <option value="eligible">31111 — Veterinarians</option>
              </optgroup>
              <optgroup label="Allied Health Professionals (TEER 1)">
                <option value="eligible">31100 — Optometrists</option>
                <option value="eligible">31110 — Pharmacists</option>
                <option value="eligible">31120 — Dietitians &amp; nutritionists</option>
                <option value="eligible">31200 — Audiologists &amp; speech-language pathologists</option>
                <option value="eligible">31201 — Physiotherapists</option>
                <option value="eligible">31202 — Occupational therapists</option>
                <option value="eligible">31209 — Other professional health diagnoses &amp; treating</option>
              </optgroup>
              <optgroup label="Nursing (TEER 1)">
                <option value="eligible">31301 — Registered nurses &amp; registered psychiatric nurses</option>
                <option value="eligible">31302 — Nurse practitioners</option>
                <option value="eligible">31303 — Physician assistants</option>
              </optgroup>
              <optgroup label="Technical Health Occupations (TEER 2)">
                <option value="eligible">32101 — Dental hygienists &amp; dental therapists</option>
                <option value="eligible">32102 — Medical radiation technologists</option>
                <option value="eligible">32103 — Medical laboratory technologists</option>
                <option value="eligible">32104 — Respiratory therapists</option>
                <option value="eligible">32110 — Medical sonographers</option>
                <option value="eligible">32111 — Cardiology technologists &amp; electrophysiology</option>
                <option value="eligible">32112 — Pharmacy technicians</option>
                <option value="eligible">32120 — Opticians</option>
                <option value="eligible">32121 — Dental technologists &amp; therapists (other)</option>
              </optgroup>
              <optgroup label="Licensed Practical Nurses (TEER 2)">
                <option value="eligible">32301 — Licensed practical nurses</option>
              </optgroup>
