        <a href="/express-entry-calculator">✈️ Express Entry</a>
        <a href="/fsw-calculator">👔 FSW Calculator</a>
        <a href="/cec-calculator">🍁 CEC Calculator</a>
        <a href="/crs-cutoff-scores">📊 Cutoff History</a>
        <a href="/improve-crs-score">📈 Improve Score</a>
      </nav>
