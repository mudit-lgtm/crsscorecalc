    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Sum all sections for your CRS score",
      "text": "CRS total = Section A + Section B + Section C + Section D. Maximum is 1,200 points. Compare with the latest Express Entry draw cutoffs to assess your invitation likelihood."
    }
  ]
}
</script>

