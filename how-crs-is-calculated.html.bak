    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Add Section B — Spouse Factors (if applicable)",
      "text": "If your spouse accompanies you, add up to 40 points from their education (10), language (20) and Canadian work experience (10)."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Calculate Section C — Skill Transferability",
      "text": "Identify qualifying combinations of education + language, experience + language, or experience + education. Each combination earns 13–25 pts, capped at 100 total."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Add Section D — Additional Points",
