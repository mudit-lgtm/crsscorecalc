<script>
// Hamburger menu
const menuBtn = document.getElementById('menuBtn');
const navLinks = document.getElementById('navLinks');
menuBtn.addEventListener('click', () => {
  const open = navLinks.classList.toggle('open');
  menuBtn.setAttribute('aria-expanded', String(open));
});

// FAQ accordion
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const ans = document.getElementById(btn.getAttribute('aria-controls'));
    const icon = btn.querySelector('.faq-icon');
    const isOpen = ans.classList.toggle('open');
    icon.classList.toggle('open', isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
});

// FST CRS Calculator Logic
function getVal(id) { return parseFloat(document.getElementById(id).value) || 0; }
function getSel(id) { return document.getElementById(id).value; }

document.getElementById('calcBtn').addEventListener('click', function () {
  const age = getVal('age');
  const edu = getVal('education');
  const married = getSel('marital') === 'married';

  // Language scores
  const ls = getVal('l1s'), ll = getVal('l1l'), lr = getVal('l1r'), lw = getVal('l1w');
  const langScore = ls + ll + lr + lw;

  const canExp = getVal('canExp');
  const forExp = getVal('forExp');

  // Core A — singles vs married
  let coreA;
  if (married) {
    coreA = Math.round(age * 0.9 + edu * 0.82 + langScore * 0.9 + canExp * 0.85);
  } else {
    coreA = age + edu + langScore + canExp;
  }

  // Spouse bonus (Section B)
  const spouseEdu  = getVal('spouseEdu');
  const spouseExp  = getVal('spouseExp');
  const spouseLang = getVal('spouseLang');
  const coreB = married ? Math.min(40, spouseEdu + spouseExp + spouseLang) : 0;

  // Skill Transferability (Section C) — capped at 100
  let skillTrans = 0;
  if (edu >= 120 && langScore >= 80) skillTrans += 50;
  else if (edu >= 90  && langScore >= 60) skillTrans += 25;
  if (canExp >= 40 && langScore >= 80) skillTrans += 25;
  if (canExp >= 40 && edu >= 120)        skillTrans += 25;
  if (forExp > 0  && canExp >= 40)        skillTrans += 25;
  // Trades-specific: foreign trades exp + Canadian exp or cert
  if (forExp > 0 && getSel('tradeCert') === 'yes') skillTrans += 25;
  skillTrans = Math.min(100, skillTrans);

  // Additional Points (Section D)
  const pnp        = getVal('pnp');
  const jobOffer   = getVal('jobOffer');
  const sibling    = getVal('sibling');
  const canadianEdu= getVal('canadianEdu');
  const frenchLang = getVal('frenchLang');
  const addPoints  = pnp + jobOffer + sibling + canadianEdu + frenchLang;

  const total = Math.min(1200, coreA + coreB + skillTrans + addPoints);

  // Update display
  document.getElementById('totalScore').textContent = total;
  document.getElementById('rCore').textContent = coreA + coreB;
  document.getElementById('rLang').textContent = langScore;
  document.getElementById('rWork').textContent = canExp + forExp;
  document.getElementById('rExtra').textContent = skillTrans + addPoints;

  // FST Eligibility check
  const tradeOcc  = getSel('tradeOcc') === 'yes';
  const tradeExp  = getSel('tradeExp') === 'yes';
  const tradeCert = getSel('tradeCert') === 'yes';
  const jobOfferFST = getSel('jobOfferFST') === 'yes';
  const clbSpeak  = ls >= 8;  // CLB 5 = value 8
  const clbRead   = lr >= 6;  // CLB 4 = value 6
  const langOK    = clbSpeak && (ll >= 8) && clbRead && (lw >= 6);
  const certOrOffer = tradeCert || jobOfferFST;

  const eligEl = document.getElementById('fstEligibility');
  let eligHTML = '';

  if (!tradeOcc) {
    eligHTML = '<div class="fst-tag tag-red">❌ Occupation not in eligible NOC TEER 2–3 trade groups. Consider <a href="/fsw-calculator" style="color:var(--red)">FSW Calculator</a> for TEER 0/1 professions.</div>';
  } else if (!tradeExp) {
    eligHTML = '<div class="fst-tag tag-amber">⚡ Need 2 years of full-time trade experience to qualify for FST program.</div>';
  } else if (!langOK) {
    eligHTML = '<div class="fst-tag tag-amber">⚡ Language below FST minimum. Need CLB 5 Speaking/Listening and CLB 4 Reading/Writing. Use <a href="/clb-scores">CLB Converter</a> to check.</div>';
  } else if (!certOrOffer) {
    eligHTML = '<div class="fst-tag tag-amber">⚡ Need either a certificate of qualification OR a Canadian job offer to qualify for FST program.</div>';
  } else {
    eligHTML = '<div class="fst-tag tag-green">✅ Meets FST eligibility requirements (trade, experience, language, cert/offer).</div>';
  }
  eligEl.innerHTML = eligHTML;

  // Draw competitiveness tag
  const drawType = getSel('tradeDrawType');
  const drawEl = document.getElementById('fstDrawTag');
  let drawHTML = '';
  const cutoffs = { trades: 477, allprogram: 505, pnp: 793 };
  const cutoff = cutoffs[drawType] || 477;
  const drawNames = { trades: 'Trade Occupations (cutoff ~477)', allprogram: 'All-Program (cutoff ~505)', pnp: 'PNP Draw (cutoff ~793)' };

  if (total >= cutoff + 10) {
    drawHTML = `<div class="fst-tag tag-green" style="margin-top:6px;">🎯 CRS ${total} is competitive for ${drawNames[drawType]} draws. You likely qualify in the next round!</div>`;
  } else if (total >= cutoff - 20) {
    drawHTML = `<div class="fst-tag tag-amber" style="margin-top:6px;">⚡ CRS ${total} is close to the ${drawNames[drawType]} cutoff. See <a href="/improve-score">Improve Score tips</a> to push over.</div>`;
  } else {
    drawHTML = `<div class="fst-tag tag-red" style="margin-top:6px;">❌ CRS ${total} is below ${drawNames[drawType]} cutoff. Use our <a href="/improve-score" style="color:var(--red)">Improve CRS Score guide</a> to boost points.</div>`;
  }
  drawEl.innerHTML = drawHTML;

  // Show result
  const box = document.getElementById('resultBox');
  box.classList.add('show');
  box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>

</body>
</html>
